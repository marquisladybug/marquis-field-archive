---
import SeriesBadge from "@/components/SeriesBadge.astro";

interface Props {
  title: string;
  series: "Urban Structure Study" | "Urban Drift";
  date: string;
  location: string;
}

const { title, series, date, location } = Astro.props;
---

<div class="photo-meta">
  <h2>{title}</h2>
  <div class="meta-line">
    <SeriesBadge series={series} />
    <span>{date}</span>
    <span>{location}</span>
  </div>
</div>

<style>
  .photo-meta {
    display: grid;
    gap: 8px;
  }

  h2 {
    margin: 0;
    font-size: clamp(17px, 1.8vw, 23px);
    font-weight: 500;
    line-height: 1.18;
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 7px 12px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }
</style>
