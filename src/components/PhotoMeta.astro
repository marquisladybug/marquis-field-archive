---
import SeriesBadge from "@/components/SeriesBadge.astro";

interface Props {
  title: string;
  series: "Urban Structure Study" | "Urban Drift";
  date: string;
  displayDate?: string;
}

const { title, series, date, displayDate } = Astro.props;
const [year, month] = date.split("-");
const visibleDate = displayDate ?? (year && month ? `${year}.${month}` : date);
---

<div class="photo-meta">
  <SeriesBadge series={series} />
  <h2>{title}</h2>
  <p class="meta-date">{visibleDate}</p>
</div>

<style>
  .photo-meta {
    display: grid;
    gap: 5px;
  }

  h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(15px, 1.15vw, 18px);
    font-weight: 500;
    line-height: 1.22;
  }

  .meta-date {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: clamp(10px, 0.8vw, 12px);
  }
</style>
