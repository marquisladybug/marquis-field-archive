---
interface Props {
  series: "Urban Structure Study" | "Urban Drift";
}

const { series } = Astro.props;
---

<span class:list={["series-badge", series === "Urban Drift" && "series-badge--drift"]}>
  {series}
</span>

<style>
  .series-badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    padding: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: clamp(10px, 0.75vw, 11px);
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .series-badge--drift {
    color: var(--muted);
  }
</style>
