---
import { withBase } from "@/lib/paths";

const navItems = [
  { href: "/urban-structure-study/", label: "Structure" },
  { href: "/urban-drift/", label: "Drift" },
  { href: "/runtime/", label: "Runtime" },
  { href: "/about/", label: "About" }
];
---

<header class="site-header">
  <a class="brand" href={withBase("/")} aria-label="Marquis Ladybug Field Archive home">
    <span>Marquis Ladybug</span>
    <span>Field Archive</span>
  </a>
  <nav class="nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    width: min(var(--max), calc(100vw - 40px));
    margin: 0 auto;
    padding: 14px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid var(--border-soft);
  }

  .brand {
    display: grid;
    gap: 2px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .brand span:last-child {
    color: var(--muted);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px 14px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: clamp(12px, 0.95vw, 13px);
    line-height: 1.6;
  }

  .nav a {
    white-space: nowrap;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: var(--text);
  }

  @media (max-width: 760px) {
    .site-header {
      width: calc(100vw - 24px);
      display: grid;
      gap: 10px;
      padding: 13px 0;
    }

    .nav {
      justify-content: flex-start;
      gap: 4px 12px;
      max-width: 100%;
    }
  }
</style>
