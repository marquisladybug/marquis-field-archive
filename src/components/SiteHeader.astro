---
import { withBase } from "@/lib/paths";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/archive/", label: "Archive" },
  { href: "/urban-structure-study/", label: "Structure" },
  { href: "/urban-drift/", label: "Drift" },
  { href: "/runtime/", label: "Runtime" },
  { href: "/about/", label: "About" }
];
---

<header class="site-header">
  <a class="brand" href={withBase("/")} aria-label="Marquis Ladybug Field Archive home">
    <span>Marquis Ladybug</span>
    <span>Field Archive</span>
  </a>
  <nav class="nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    width: min(var(--max), calc(100vw - 40px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--border);
  }

  .brand {
    display: grid;
    gap: 2px;
    color: var(--text);
    font-size: 13px;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .brand span:last-child {
    color: var(--muted);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px 18px;
    color: var(--muted);
    font-size: 12px;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: var(--text);
  }

  @media (max-width: 760px) {
    .site-header {
      width: calc(100vw - 24px);
      display: grid;
      padding-top: 18px;
    }

    .nav {
      justify-content: flex-start;
    }
  }
</style>
