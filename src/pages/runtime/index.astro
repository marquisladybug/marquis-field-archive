---
import BaseLayout from "@/layouts/BaseLayout.astro";

const runtimeUrl = "https://marquisladybug.github.io/marquis-ladybug-earth/index.html";
---

<BaseLayout title="Runtime" description="Planetary Runtime link for Marquis Ladybug, separate from the photo archive.">
  <main class="page">
    <section class="section split">
      <div>
        <p class="kicker">Upper control surface</p>
      </div>
      <div class="text-block">
        <h1 class="page-title">Planetary Runtime</h1>
        <p>
          Planetary Runtime exists above this archive as a separate control surface. This site remains a field archive for photographs and observation logs.
        </p>
        <p>
          The archive records what was seen. Runtime coordinates the larger Civilization OS surface.
        </p>
        <a class="text-link" href={runtimeUrl} rel="noreferrer" target="_blank">Open Planetary Runtime</a>
      </div>
    </section>
  </main>
</BaseLayout>
