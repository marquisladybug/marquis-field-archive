---
import BaseLayout from "@/layouts/BaseLayout.astro";

const runtimeUrl = "https://marquisladybug.github.io/marquis-ladybug-earth/index.html";
---

<BaseLayout title="Runtime" description="Planetary Runtime link for Marquis Ladybug, separate from the photo archive.">
  <main class="page">
    <section class="section">
      <h1 class="label-title">Planetary Runtime</h1>
      <div class="text-block label-copy-block">
        <p>
          Planetary Runtime is the upper observation surface for Marquis Ladybug. It reads Earth imagery, cloud layers, orbital paths, daylight, darkness, and atmospheric motion as planetary-scale runtime conditions.
        </p>
        <p>
          The Field Archive records local urban surfaces. Runtime watches the larger operating layer: weather, orbit, illumination, and the still-running planetary circuit beneath Civilization OS.
        </p>
        <a class="text-link" href={runtimeUrl} rel="noreferrer" target="_blank">Open Planetary Runtime</a>
      </div>
    </section>
  </main>
</BaseLayout>
