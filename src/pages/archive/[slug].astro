---
import { Image } from "astro:assets";
import PhotoLayout from "@/layouts/PhotoLayout.astro";
import PhotoMeta from "@/components/PhotoMeta.astro";
import { withBase } from "@/lib/paths";
import { getAdjacentPhotos, getPhotoSlug, getPhotos, getSeriesPhotos, resolvePhotoImage } from "@/lib/photos";

export async function getStaticPaths() {
  const photos = await getPhotos();
  return photos.map((photo) => {
    const seriesPhotos = getSeriesPhotos(photos, photo.data.series);
    const neighbors = getAdjacentPhotos(seriesPhotos, getPhotoSlug(photo));

    return {
      params: { slug: getPhotoSlug(photo) },
      props: {
        photo,
        previousPhoto: neighbors.previous,
        nextPhoto: neighbors.next
      }
    };
  });
}

const { photo, previousPhoto, nextPhoto } = Astro.props;
const image = resolvePhotoImage(photo.data.image);
---

<PhotoLayout photo={photo}>
  <main class="page page--detail">
    <article class="detail">
      <figure class:list={["detail-figure", !image && "detail-figure--missing"]}>
        <div class="detail-image">
          {
            typeof image === "string" ? (
              <img src={image} alt={photo.data.title} />
            ) : image ? (
              <Image src={image} alt={photo.data.title} widths={[900, 1400, 1800, 2200, 2600]} sizes="92vw" />
            ) : (
              <div class="missing-image">Image pending</div>
            )
          }
        </div>

        <figcaption class="detail-meta">
          <PhotoMeta
            title={photo.data.title}
            series={photo.data.series}
            date={photo.data.date}
          />

          {(previousPhoto || nextPhoto) && (
            <nav class="photo-navigation" aria-label="Adjacent photos">
              <div>
                {previousPhoto && (
                  <a href={withBase(`/archive/${getPhotoSlug(previousPhoto)}/`)}>
                    <span aria-hidden="true">&larr;</span> Previous: {previousPhoto.data.title}
                  </a>
                )}
              </div>

              <div class="photo-navigation__next">
                {nextPhoto && (
                  <a href={withBase(`/archive/${getPhotoSlug(nextPhoto)}/`)}>
                    Next: {nextPhoto.data.title} <span aria-hidden="true">&rarr;</span>
                  </a>
                )}
              </div>
            </nav>
          )}
        </figcaption>
      </figure>
    </article>
  </main>
</PhotoLayout>

<style>
  .detail {
    display: block;
  }

  .detail-figure {
    width: fit-content;
    max-width: 100%;
    margin: 0 auto;
  }

  .detail-figure--missing {
    width: 100%;
  }

  .detail-image {
    display: grid;
    place-items: center;
  }

  .detail-image img,
  .detail-image :global(picture img) {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 76vh;
    object-fit: contain;
    margin: 0 auto;
  }

  .detail-image :global(picture) {
    display: grid;
    place-items: center;
    max-width: 100%;
  }

  .detail-meta {
    width: 100%;
    margin-top: 12px;
    text-align: left;
  }

  .detail-meta :global(.photo-meta h2) {
    font-size: clamp(15px, 1.15vw, 18px);
  }

  .photo-navigation {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 18px;
    margin-top: 18px;
    padding-top: 12px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: clamp(10px, 0.78vw, 11px);
    letter-spacing: 0.04em;
    line-height: 1.45;
  }

  .photo-navigation a {
    border-bottom: 1px solid transparent;
  }

  .photo-navigation a:hover,
  .photo-navigation a:focus-visible {
    color: var(--text);
    border-color: var(--border);
  }

  .photo-navigation__next {
    text-align: right;
  }

  .missing-image {
    width: 100%;
    min-height: min(56vh, 520px);
    display: grid;
    place-items: center;
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .detail-figure {
      width: 100%;
    }

    .detail-image img,
    .detail-image :global(picture img) {
      max-height: 82vh;
    }

    .photo-navigation {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .photo-navigation__next {
      text-align: left;
    }
  }
</style>
