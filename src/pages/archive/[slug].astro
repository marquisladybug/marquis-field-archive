---
import { Image } from "astro:assets";
import PhotoLayout from "@/layouts/PhotoLayout.astro";
import PhotoMeta from "@/components/PhotoMeta.astro";
import { getPhotoSlug, getPhotos, resolvePhotoImage } from "@/lib/photos";

export async function getStaticPaths() {
  const photos = await getPhotos();
  return photos.map((photo) => ({
    params: { slug: getPhotoSlug(photo) },
    props: { photo }
  }));
}

const { photo } = Astro.props;
const image = resolvePhotoImage(photo.data.image);
---

<PhotoLayout photo={photo}>
  <main class="page page--detail">
    <article class="detail">
      <figure class="detail-image">
        {
          typeof image === "string" ? (
            <img src={image} alt={photo.data.title} />
          ) : image ? (
            <Image src={image} alt={photo.data.title} widths={[900, 1400, 1800, 2200, 2600]} sizes="92vw" />
          ) : (
            <div class="missing-image">Image pending</div>
          )
        }
      </figure>

      <div class="detail-body">
        <PhotoMeta
          title={photo.data.title}
          series={photo.data.series}
          date={photo.data.date}
        />
      </div>
    </article>
  </main>
</PhotoLayout>

<style>
  .detail {
    display: grid;
    gap: 18px;
  }

  .detail-image {
    margin: 0;
    min-height: 48vh;
    background: var(--panel);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .detail-image img,
  .detail-image :global(picture),
  .detail-image :global(picture img) {
    width: 100%;
  }

  .detail-image img,
  .detail-image :global(picture img) {
    height: auto;
  }

  .detail-body {
    max-width: 820px;
    display: grid;
    gap: 12px;
  }

  .detail-body :global(.photo-meta h2) {
    font-size: clamp(15px, 1.15vw, 18px);
  }

  .missing-image {
    min-height: 60vh;
    display: grid;
    place-items: center;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .detail-image {
      width: calc(100vw - 24px);
      margin-left: 50%;
      transform: translateX(-50%);
    }
  }
</style>
