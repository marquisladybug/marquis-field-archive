---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotoGrid from "@/components/PhotoGrid.astro";
import { getFeaturedPhotos, getPhotos, resolvePhotoImage } from "@/lib/photos";
import { withBase } from "@/lib/paths";

const photos = await getPhotos();
const featured = getFeaturedPhotos(photos).slice(0, 4);
const hero = featured[0] ?? photos[0];
const heroImage = hero ? resolvePhotoImage(hero.data.image) : undefined;
---

<BaseLayout>
  <main class="page">
    <section class="hero">
      <figure>
        {
          typeof heroImage === "string" ? (
            <img src={heroImage} alt={hero ? `${hero.data.title}, ${hero.data.location}` : "Archive placeholder"} />
          ) : heroImage ? (
            <Image src={heroImage} alt={`${hero.data.title}, ${hero.data.location}`} widths={[900, 1400, 1800, 2200]} sizes="calc(100vw - 40px)" loading="eager" />
          ) : null
        }
      </figure>
      <div class="hero-text">
        <p class="kicker">Civilization OS field logs</p>
        <h1 class="page-title hero-title">Marquis Ladybug Field Archive</h1>
        <p class="page-copy">
          A quiet photo archive for urban structures, movement, light, and human trace observations by Marquis Ladybug / てんとうむし侯爵.
        </p>
        <div class="link-row" aria-label="Archive sections">
          <a class="text-link" href={withBase("/archive/")}>Archive</a>
          <a class="text-link" href={withBase("/urban-structure-study/")}>Urban Structure Study</a>
          <a class="text-link" href={withBase("/urban-drift/")}>Urban Drift</a>
          <a class="text-link" href={withBase("/runtime/")}>Runtime</a>
          <a class="text-link" href={withBase("/about/")}>About</a>
        </div>
      </div>
    </section>

    <section class="section">
      <p class="kicker">Featured entries</p>
      <PhotoGrid photos={featured} featured />
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 28px;
  }

  figure {
    margin: 0;
    background: var(--panel);
    border: 1px solid var(--border-soft);
    aspect-ratio: 21 / 8;
    max-height: 430px;
    overflow: hidden;
  }

  figure img,
  figure :global(picture),
  figure :global(picture img) {
    width: 100%;
    height: 100%;
  }

  figure img,
  figure :global(picture img) {
    object-fit: cover;
  }

  .hero-text {
    order: -1;
    max-width: 900px;
  }

  .hero-title {
    font-size: clamp(38px, 6vw, 68px);
  }

  @media (max-width: 760px) {
    figure {
      width: calc(100vw - 24px);
      margin-left: 50%;
      transform: translateX(-50%);
      aspect-ratio: 16 / 10;
      max-height: none;
    }
  }
</style>
