---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
---

<BaseLayout>
  <main class="page">
    <section class="home-index">
      <p class="kicker">Civilization OS field logs</p>
      <h1 class="visually-hidden">Marquis Ladybug Field Archive</h1>
      <nav class="series-access" aria-label="Archive series">
        <a href={withBase("/urban-structure-study/")}>Urban Structure Study</a>
        <a href={withBase("/urban-drift/")}>Urban Drift</a>
      </nav>
    </section>
  </main>
</BaseLayout>

<style>
  .home-index {
    display: grid;
    gap: 18px;
    padding-top: 8px;
  }

  .series-access {
    display: grid;
    gap: 8px;
    width: fit-content;
    color: var(--text);
    font-family: var(--font-body);
    font-size: clamp(14px, 1vw, 16px);
    line-height: 1.35;
  }

  .series-access a {
    width: fit-content;
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 2px;
  }

  .series-access a:hover,
  .series-access a:focus-visible {
    border-color: var(--text);
  }
</style>
