---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotoGrid from "@/components/PhotoGrid.astro";
import { getPhotos, getSeriesPhotos } from "@/lib/photos";

const photos = getSeriesPhotos(await getPhotos(), "Urban Drift");
---

<BaseLayout title="Urban Drift" description="Softer movement, light, and human trace observations from the Marquis Ladybug Field Archive.">
  <main class="page drift-page">
    <section class="section">
      <p class="kicker">Series 02</p>
      <h1 class="page-title">Urban Drift</h1>
      <p class="page-copy">Movement, light, thresholds, and passing traces. Still archival, with more air around the frame.</p>
    </section>
    <PhotoGrid photos={photos} />
  </main>
</BaseLayout>

<style>
  .drift-page {
    --max: 1540px;
  }
</style>
