---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotoGrid from "@/components/PhotoGrid.astro";
import { getPhotos, getSeriesPhotos } from "@/lib/photos";

const photos = getSeriesPhotos(await getPhotos(), "Urban Drift");
---

<BaseLayout title="Urban Drift" description="Urban Drift archive index.">
  <main class="page drift-page">
    <section class="index-head">
      <p class="kicker">URBAN DRIFT</p>
    </section>
    <PhotoGrid photos={photos} />
  </main>
</BaseLayout>

<style>
  .drift-page {
    --max: 1540px;
  }
</style>
