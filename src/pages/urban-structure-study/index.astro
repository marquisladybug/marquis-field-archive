---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotoGrid from "@/components/PhotoGrid.astro";
import { getPhotos, getSeriesPhotos } from "@/lib/photos";

const photos = getSeriesPhotos(await getPhotos(), "Urban Structure Study");
---

<BaseLayout title="Urban Structure Study" description="Hard infrastructure observation logs from the Marquis Ladybug Field Archive.">
  <main class="page">
    <section class="index-head">
      <p class="kicker">URBAN STRUCTURE STUDY</p>
    </section>
    <PhotoGrid photos={photos} />
  </main>
</BaseLayout>
